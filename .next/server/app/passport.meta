{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/passport/layout,_N_T_/passport/page,_N_T_/passport"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/passport/__PAGE__",
    "/passport",
    "/_index",
    "/_head"
  ]
}